"""
Project 1 – Webpage Fetching Tool

This program fetches a webpage and displays:
- Page title
- Body text
- All hyperlinks
"""

import sys
import urllib.request
import ssl
from html.parser import HTMLParser


ssl_context = ssl._create_unverified_context()


class MyHTMLParser(HTMLParser):
    """
    Extracts title, body text and hyperlinks from a webpage.
    """

    def __init__(self):
        super().__init__()
        self.in_title = False
        self.in_body = False
        self.title_text = ""
        self.body_text = ""
        self.links = []

    def handle_starttag(self, tag, attrs):
        if tag == "title":
            self.in_title = True
        elif tag == "body":
            self.in_body = True
        elif tag == "a":
            for attr in attrs:
                if attr[0] == "href":
                    self.links.append(attr[1])

    def handle_endtag(self, tag):
        if tag == "title":
            self.in_title = False
        elif tag == "body":
            self.in_body = False

    def handle_data(self, data):
        if self.in_title:
            self.title_text += data.strip()

        if self.in_body:
            text = data.strip()
            if text:
                self.body_text += text + " "


def fetch_page(url):

    request = urllib.request.Request(
        url,
        headers={'User-Agent': 'Mozilla/5.0'}
    )

    response = urllib.request.urlopen(request, context=ssl_context)
    html_content = response.read().decode("utf-8", errors="ignore")

    parser = MyHTMLParser()
    parser.feed(html_content)

    return parser


def main():

    if len(sys.argv) != 2:
        print("Usage: python3 web_fetcher.py <URL>")
        return

    url = sys.argv[1]

    try:
        parser = fetch_page(url)
    except Exception as e:
        print("Could not open the page.")
        print("Reason:", e)
        return

    print("\nPage Title:")
    print(parser.title_text.strip())

    print("\nBody Text:")
    print(parser.body_text.strip())

    print("\nLinks Found:")
    for link in parser.links:
        print(link)


if __name__ == "__main__":
    main()
